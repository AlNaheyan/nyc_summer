# Summer Quest NYC — environment variables (see TECH_SPEC §4)
# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (Project Settings → Database). Used by db:migrate / db:seed.
SUPABASE_DB_URL=

# --- Image moderation (Sightengine) — required before the feed auto-publishes ---
# Without these, every photo is held as "flagged" (never auto-public).
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
MODERATION_API_KEY=

# --- OAuth providers (configured in the Supabase Auth dashboard) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_SERVICE_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=

# --- Maps (Mapbox) ---
# Public token (pk.…) for the location card map headers (Static Images API).
# Without it, cards fall back to a styled placeholder. Free tier: 50k/month.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
